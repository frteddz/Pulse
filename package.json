{
  "name": "pulse",
  "private": true,
  "version": "0.0.1BETA",
  "description": "Pulse | desktop system monitor",
  "author": {
    "name": "Teddz",
    "email": "teddzfr@proton.me"
  },
  "homepage": "https://github.com/frteddz/pulse",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "package:dev": "npm run dev:electron",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:all": "npm run package:win && npm run package:linux && npm run package:mac",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.teddz.pulse",
    "productName": "Pulse",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "Beta"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Utility"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "concurrently": "^10.0.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "systeminformation": "^5.27.0",
    "tailwindcss": "^4.3.2",
    "wait-on": "^9.0.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.2",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
