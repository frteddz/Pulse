{
  "appId": "com.teddz.pulse",
  "productName": "Pulse",
  "icon": "build/icon-rgba.png",
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "directories": {
    "buildResources": "build",
    "output": "Beta"
  },
  "extraMetadata": {
    "main": "electron/main.cjs"
  },
  "win": {
    "target": ["nsis"]
  },
  "linux": {
    "target": ["deb"],
    "category": "Utility",
    "syncDesktopName": true,
    "icon": "build/icon.png"
  }
}
